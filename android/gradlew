#!/bin/sh

# Gradle Wrapper script for Unix/Linux/macOS
# Standard professional wrapper to ensure build consistency

APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`

# Use the maximum power of the machine
DEFAULT_JVM_OPTS="-Xmx2g -XX:MaxMetaspaceSize=512m"

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# Find the java executable
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Run the wrapper
exec "$JAVACMD" $DEFAULT_JVM_OPTS -classpath "gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
